---
import AppLayout from "../layouts/AppLayout.astro";
import { tools, getToolUrl } from "../lib/tools";
---

<AppLayout title="Stoic Tools — Catálogo">
  <header class="border-b border-muted/20 px-6 py-4">
    <h1 class="text-xl font-bold text-foreground">Ferramentas</h1>
    <p class="mt-1 text-sm text-muted">
      Utilitários rápidos de página única. Escolha uma ferramenta para começar.
    </p>
  </header>

  <main class="flex-1 overflow-y-auto p-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool) => (
        <a
          href={getToolUrl(tool)}
          class="group rounded-xl border border-muted/20 bg-panel p-5 transition-colors hover:border-accent/40 hover:bg-accent/5"
        >
          <div class="mb-3 text-accent">
            <!-- Icon rendered as SVG placeholder since Astro can't render React icons directly -->
            <span class="text-lg font-bold">{tool.name.charAt(0)}</span>
          </div>
          <h2 class="font-semibold text-foreground group-hover:text-accent transition-colors">
            {tool.name}
          </h2>
          <p class="mt-1 text-sm text-muted">{tool.description}</p>
          <span class="mt-3 inline-block text-xs text-muted/60">{tool.category}</span>
        </a>
      ))}
    </div>
  </main>
</AppLayout>
