---
import "../styles/globals.css";
import { AppSidebar } from "../components/app-sidebar";
import { ThemeSwitcher } from "../components/theme-switcher";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Stoic Tools", description = "Utilitários rápidos de página única para o dia a dia." } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site ?? Astro.url.origin).href;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-surface">
    <div class="flex min-h-screen">
      <AppSidebar client:load currentPath={currentPath} />
      <div class="flex flex-1 flex-col md:ml-0">
        <div class="flex justify-end px-4 py-2">
          <ThemeSwitcher client:load />
        </div>
        <slot />
      </div>
    </div>
  </body>
</html>
